{
  "name": "slick",
  "private": true,
  "scripts": {
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:sh": "git ls-files '*.sh' | xargs shellcheck -S warning",
    "render": "scripts/byoe/render-icon.sh",
    "validate": "node scripts/ci/validate.js",
    "check": "npm run fmt:check && npm run lint && npm run lint:sh && npm run validate"
  },
  "devDependencies": {
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0"
  }
}
