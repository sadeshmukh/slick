{
  "name": "Ultraviolet",
  "description": "A nice dark-violet theme",
  "vars": {
    "--dt_color-base-pry": "#16111f",
    "--dt_color-base-sec": "#16111f",
    "--dt_color-base-ter": "#1f1733",
    "--dt_color-base-inv-pry": "#1f1733",
    "--dt_color-ctr-pry": "#1f1733",
    "--dt_color-ctr-sec": "#1f1733",
    "--sk_primary_background": "22,17,31",

    "--dt_color-content-hgl-1": "#4c12a3",
    "--dt_color-base-hgl-1": "#eee3ff",
    "--dt_color-base-inv-hgl-1": "#4c12a3",
    "--dt_color-base-hgl-1-hover": "rgba(66, 0, 164, 0.059)",
    "--dt_color-base-hgl-1-pressed": "rgba(66, 0, 164, 0.129)",
    "--dt_color-base-inv-hgl-1-hover": "rgba(46, 18, 89, 0.129)",
    "--dt_color-base-inv-hgl-1-pressed": "rgba(46, 18, 89, 0.22)",
    "--dt_color-surf-hgl-1": "rgba(128, 54, 240, 0.129)",
    "--dt_color-surf-hgl-1-hover": "rgba(66, 0, 164, 0.09)",
    "--dt_color-surf-hgl-1-pressed": "rgba(66, 0, 164, 0.129)",
    "--dt_color-content-inv-hgl-1": "#c39efa",
    "--dt_color-otl-hgl-1": "#4c12a3",
    "--dt_color-otl-hgl-1-sec": "rgba(93, 14, 211, 0.2)"
  },
  "sidebar": {
    "nav-bg": "#1A1525",
    "text-color": "#D8CCF0",
    "badge": "#8B5CF6",
    "badge-text-color": "#FFFFFF"
  },
  "css": [
    "body::before{content:'';position:fixed;inset:0;z-index:0;background:#16111f;pointer-events:none;}",
    ".p-theme_background{background:radial-gradient(130% 90% at 50% -10%, #34205e 0%, #160f24 58%) !important;}",
    ".p-theme_background:after{backdrop-filter:none !important;background:transparent !important;}",
    ".p-message_input__input_container_unstyled,.c-wysiwyg_container--theme_dark{background-color:#1b1430 !important;border:1px solid #3a2d57 !important;}",
    ".c-wysiwyg_container__formatting{background:#1b1430 !important;}",
    "[role=menu],[role=dialog],[role=listbox],.c-menu,.p-ia4_floating_window,.c-popover__content{background-color:#1b1430 !important;border:1px solid #3a2d57 !important;}",
    ".c-message_kit__background--hovered:not(.c-message_kit__background--highlight):not(.c-message_kit__background--editing):not(.c-message_kit__background--huddle):not(.c-message_kit__background--deleting){background:#241b3a !important;}",
    ".c-message:hover:not(.c-message--highlight):not(.c-message--standalone):not(.c-message--pinned):not(.c-message--ephemeral):not(.c-message--custom_response):not(.c-message--starred),.c-message--hover:not(.c-message--highlight):not(.c-message--standalone):not(.c-message--pinned):not(.c-message--ephemeral):not(.c-message--custom_response):not(.c-message--starred){background:#241b3a !important;}",
    ".p-about_modal__contents{background:#1b1430 !important;border:1px solid #3a2d57 !important;}"
  ]
}
