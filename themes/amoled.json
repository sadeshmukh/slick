{
  "name": "AMOLED",
  "description": "True-black theme for OLED.",
  "palette": {
    "aubergine": { "0": "0,0,0", "10": "0,0,0" }
  },
  "vars": {
    "--dt_color-base-pry": "#000000",
    "--dt_color-base-sec": "#000000",
    "--dt_color-base-ter": "#000000",
    "--dt_color-base-inv-pry": "#000000",
    "--dt_color-ctr-pry": "#000000",
    "--dt_color-ctr-sec": "#000000",
    "--sk_primary_background": "0,0,0"
  },
  "css": [
    "body::before{content:'';position:fixed;inset:0;z-index:0;background:#000;pointer-events:none;}",
    ".p-theme_background{background:#000 !important;}",
    ".p-theme_background:after{backdrop-filter:none !important;background:#000 !important;}",
    ".p-message_input__input_container_unstyled,.c-wysiwyg_container--theme_dark{background-color:#000 !important;border:1px solid #2a2a2a !important;}",
    ".c-wysiwyg_container__formatting{background:#000 !important;}",
    ".p-context_bar_v2,[data-qa=context_bar]{background:#000 !important;border:1px solid #2a2a2a !important;}",
    ".p-context_bar_v2__content,.p-context_bar_v2__icon{color:#d1d2d3 !important;}",
    "[role=menu],[role=dialog],[role=listbox],.c-menu,.p-ia4_floating_window,.c-popover__content{background-color:#000 !important;border:1px solid #2a2a2a !important;}",
    ".c-message_kit__background--hovered:not(.c-message_kit__background--highlight):not(.c-message_kit__background--editing):not(.c-message_kit__background--huddle):not(.c-message_kit__background--deleting){background:#121416 !important;}",
    ".c-message:hover:not(.c-message--highlight):not(.c-message--standalone):not(.c-message--pinned):not(.c-message--ephemeral):not(.c-message--custom_response):not(.c-message--starred),.c-message--hover:not(.c-message--highlight):not(.c-message--standalone):not(.c-message--pinned):not(.c-message--ephemeral):not(.c-message--custom_response):not(.c-message--starred){background:#121416 !important;}",
    ".p-about_modal__contents{background:#000 !important;border:1px solid #2a2a2a !important;}"
  ]
}
